@page "/settings/locations/configure/{LocationId:int}"
@rendermode InteractiveServer
@using CulinaryCommand.Data.Entities
@using CulinaryCommand.Vendor.Entities
@using CulinaryCommand.Vendor.Services
@using CulinaryCommand.Services
@using CulinaryCommand.Services.UserContextSpace
@using CulinaryCommandApp.Inventory.Entities
@using CulinaryCommandApp.Inventory.Services
@using CulinaryCommandApp.Inventory.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using System.Text.Json
@attribute [Authorize]

@inject IVendorService VendorService
@inject ILocationService LocationService
@inject IUnitService UnitService
@inject StorageLocationService StorageLocService
@inject IUserContextService UserCtx
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IHttpClientFactory HttpFactory
@inject LogoDevService LogoDev

<PageTitle>Configure Location – Culinary Command</PageTitle>

<div class="container py-4" style="max-width: 800px;">

    @if (!_hydrated)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>
    }
    else if (_location is null)
    {
        <div class="alert alert-danger">Location not found or you don't have access to it.</div>
        <a href="/settings/locations" class="btn btn-secondary">← Back to Locations</a>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="/settings/locations" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <div>
                <h3 class="mb-0">Configure Location</h3>
                <span class="text-muted fs-6">@_location.Name · @_location.City, @_location.State</span>
            </div>
        </div>

        <!-- Vendors Section -->
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-truck me-2"></i>Vendors</h5>
                <button class="btn btn-success btn-sm" @onclick="OpenAddVendorModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Vendor
                </button>
            </div>

            <div class="card-body p-0">
                @if (!_locationVendors.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-truck fs-2 d-block mb-2"></i>
                        No vendors found for your company. Add one to get started.
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Vendor</th>
                                <th>Contact</th>
                                <th>Email / Phone</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vendor in _locationVendors)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(vendor.LogoUrl))
                                            {
                                                <img src="@vendor.LogoUrl" alt="@vendor.Name"
                                                     style="width:32px;height:32px;object-fit:contain;border-radius:4px;flex-shrink:0;" />
                                            }
                                            <div>
                                                <strong>@vendor.Name</strong>
                                                @if (!string.IsNullOrWhiteSpace(vendor.Notes))
                                                {
                                                    <br /><small class="text-muted">@vendor.Notes</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>@(vendor.ContactName ?? "—")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(vendor.Email))
                                        {
                                            <span>@vendor.Email</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(vendor.Phone))
                                        {
                                            <br /><small class="text-muted">@vendor.Phone</small>
                                        }
                                        @if (string.IsNullOrWhiteSpace(vendor.Email) && string.IsNullOrWhiteSpace(vendor.Phone))
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RemoveVendor(vendor.Id)"
                                                title="Remove vendor from this location">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            @if (_locationVendors.Any())
            {
                <div class="card-footer d-flex justify-content-end gap-2">
                    <span class="text-muted align-self-center small">@_locationVendors.Count vendor(s) at this location</span>
                </div>
            }
        </div>

        <!-- Units Section -->
        <div class="card shadow-sm mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-rulers me-2"></i>Measurement Units</h5>
                <button class="btn btn-success btn-sm" @onclick="OpenAddUnitModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Unit
                </button>
            </div>

            <div class="card-body p-0">
                @if (!_locationUnits.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-rulers fs-2 d-block mb-2"></i>
                        No units assigned to this location yet. Add one to get started.
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Abbreviation</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var unit in _locationUnits)
                            {
                                <tr>
                                    <td><strong>@unit.Name</strong></td>
                                    <td><span class="badge bg-secondary">@unit.Abbreviation</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RemoveUnit(unit.Id)"
                                                title="Remove unit from this location">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            @if (_locationUnits.Any())
            {
                <div class="card-footer d-flex justify-content-end gap-2">
                    <span class="text-muted align-self-center small">@_locationUnits.Count unit(s) at this location</span>
                </div>
            }
        </div>

        <!-- Storage Locations Section -->
        <div class="card shadow-sm mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-box-seam me-2"></i>Storage Locations</h5>
                <button class="btn btn-success btn-sm" @onclick="OpenAddStorageLocationModal">
                    <i class="bi bi-plus-circle me-1"></i>Add Storage Location
                </button>
            </div>

            <div class="card-body p-0">
                @if (!_storageLocations.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-box-seam fs-2 d-block mb-2"></i>
                        No storage locations assigned yet. Add one to get started.
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loc in _storageLocations)
                            {
                                <tr>
                                    <td>
                                        @if (_editingStorageLocationId == loc.Id)
                                        {
                                            <input type="text" class="form-control form-control-sm"
                                                @bind="_editingStorageLocationName"
                                                style="max-width: 300px;" />
                                        }
                                        else
                                        {
                                            <strong>@loc.Name</strong>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (_editingStorageLocationId == loc.Id)
                                        {
                                            <button class="btn btn-success btn-sm me-1"
                                                    @onclick="SaveStorageLocationEdit"
                                                    disabled="@_savingStorageLocation">
                                                @if (_savingStorageLocation)
                                                {
                                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-check-lg"></i>
                                                }
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="CancelStorageLocationEdit">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-primary btn-sm me-1"
                                                    @onclick="() => StartEditStorageLocation(loc)"
                                                    title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => DeleteStorageLocation(loc.Id)"
                                                    title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (!string.IsNullOrEmpty(_storageLocationDeleteError))
                    {
                        <div class="alert alert-warning mt-2 mb-0 mx-3 py-2 px-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>@_storageLocationDeleteError
                        </div>
                    }
                }
            </div>

            @if (_storageLocations.Any())
            {
                <div class="card-footer d-flex justify-content-end gap-2">
                    <span class="text-muted align-self-center small">@_storageLocations.Count storage location(s)</span>
                </div>
            }
        </div>
    }
</div>

<!-- Add Vendor Modal -->
@if (_showAddVendorModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Vendor</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddVendorModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="_newVendor" OnValidSubmit="CreateVendor">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" />

                        <!-- Logo.dev search -->
                        <div class="mb-3 position-relative">
                            <label class="form-label">Search for a company</label>
                            <div class="input-group">
                                <input class="form-control"
                                       placeholder="e.g. US Foods, Sysco..."
                                       value="@_searchQuery"
                                       @oninput="OnSearchInput"
                                       @onkeydown="OnSearchKeyDown"
                                       autocomplete="off" />
                                @if (_searching)
                                {
                                    <span class="input-group-text">
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(_selectedLogoUrl) && !_searching)
                                {
                                    <button type="button" class="btn btn-outline-secondary"
                                            title="Clear selection"
                                            @onclick="ClearSelection">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>

                            @if (_searchResults.Any())
                            {
                                <ul class="list-group position-absolute w-100 shadow-sm"
                                    style="z-index:1060; top:100%; max-height:220px; overflow-y:auto;">
                                    @for (int i = 0; i < _searchResults.Count; i++)
                                    {
                                        var result = _searchResults[i];
                                        var index = i;
                                        var isActive = index == _searchActiveIndex;
                                        <li class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2 @(isActive ? "active" : "")"
                                            style="cursor:pointer;"
                                            @onclick="() => SelectSearchResult(result)">
                                            <img src="@(result.Logo_Url ?? BuildLogoUrl(result.Domain))"
                                                 alt="@result.Name"
                                                 style="width:28px;height:28px;object-fit:contain;border-radius:4px;background:#f8f8f8;"
                                                 onerror="this.style.display='none'" />
                                            <div>
                                                <div class="fw-semibold small">@result.Name</div>
                                                <div class="text-muted" style="font-size:0.75rem;">@result.Domain</div>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }

                            @if (!string.IsNullOrEmpty(_selectedLogoUrl))
                            {
                                <div class="d-flex align-items-center gap-3 mt-2 p-2 border rounded bg-light">
                                    <img src="@_selectedLogoUrl"
                                         alt="@_newVendor.Name"
                                         style="width:48px;height:48px;object-fit:contain;border-radius:6px;background:white;padding:4px;border:1px solid #dee2e6;" />
                                    <div>
                                        <div class="fw-semibold">@_newVendor.Name</div>
                                        <div class="text-muted small">@_newVendor.Website</div>
                                    </div>
                                    <i class="bi bi-check-circle-fill text-success ms-auto fs-5"></i>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Vendor Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_newVendor.Name" placeholder="e.g. US Foods" />
                            <ValidationMessage For="() => _newVendor.Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contact Name</label>
                            <InputText class="form-control" @bind-Value="_newVendor.ContactName" placeholder="e.g. Jane Smith" />
                        </div>
                        <div class="row">
                            <div class="col mb-3">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" @bind-Value="_newVendor.Email" placeholder="contact@vendor.com" />
                            </div>
                            <div class="col mb-3">
                                <label class="form-label">Phone</label>
                                <InputText class="form-control" @bind-Value="_newVendor.Phone" placeholder="555-123-4567" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Website</label>
                            <InputText class="form-control" @bind-Value="_newVendor.Website" placeholder="https://vendor.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea class="form-control" @bind-Value="_newVendor.Notes" rows="2" placeholder="Optional notes..." />
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-secondary" @onclick="CloseAddVendorModal">Cancel</button>
                            <button type="submit" class="btn btn-success" disabled="@_creatingVendor">
                                @if (_creatingVendor)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Create Vendor
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Add Unit Modal -->
@if (_showAddUnitModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Unit to Location</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddUnitModal"></button>
                </div>
                <div class="modal-body">
                    @if (!_availableUnitsToAdd.Any())
                    {
                        <p class="text-muted">All available units are already assigned to this location.</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Select a unit</label>
                            <select class="form-select" @bind="_selectedUnitId">
                                <option value="0">-- Select Unit --</option>
                                @foreach (var unit in _availableUnitsToAdd)
                                {
                                    <option value="@unit.Id">@unit.Name (@unit.Abbreviation)</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddUnitModal">Cancel</button>
                        <button type="button" class="btn btn-success"
                                disabled="@(_selectedUnitId == 0 || _addingUnit)"
                                @onclick="AddUnit">
                            @if (_addingUnit)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Add Unit
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (_showAddStorageLocationModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Storage Location</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddStorageLocationModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Location Name</label>
                        <input type="text" class="form-control" @bind="_newStorageLocationName"
                               placeholder="e.g. Walk-in Freezer, Dry Storage..." />
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary"
                                @onclick="CloseAddStorageLocationModal">Cancel</button>
                        <button type="button" class="btn btn-success"
                                disabled="@(_savingStorageLocation || string.IsNullOrWhiteSpace(_newStorageLocationName))"
                                @onclick="CreateStorageLocation">
                            @if (_savingStorageLocation)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Add Location
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int LocationId { get; set; }

    private Location? _location;
    private List<Vendor> _locationVendors = new();
    private List<Unit> _locationUnits = new();
    private List<Unit> _availableUnitsToAdd = new();
    private List<StorageLocation> _storageLocations = new();

    private bool _hydrated;
    private bool _showAddVendorModal;
    private bool _creatingVendor;
    private bool _showAddUnitModal;
    private bool _addingUnit;
    
    // Storage Locations
    private bool _showAddStorageLocationModal;
    private bool _addingStorageLocation;
    private string _newStorageLocationName = "";
    private bool _savingStorageLocation;
    private int? _editingStorageLocationId;
    private string _editingStorageLocationName = "";
    private string? _storageLocationDeleteError;
    private int _selectedUnitId;

    private Vendor _newVendor = new();
    private int? _companyId;

    private string _searchQuery = string.Empty;
    private bool _searching;
    private List<LogoDevResult> _searchResults = new();
    private int _searchActiveIndex = -1;
    private string? _selectedLogoUrl;
    private CancellationTokenSource? _searchCts;

    protected override async Task OnInitializedAsync()
    {
        var ctx = await UserCtx.GetAsync();

        if (ctx.IsAuthenticated != true || ctx.User is null)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        var role = ctx.User.Role ?? string.Empty;
        var isAdminOrManager = role.Equals("Admin", StringComparison.OrdinalIgnoreCase)
                            || role.Equals("Manager", StringComparison.OrdinalIgnoreCase);

        if (!isAdminOrManager)
        {
            Nav.NavigateTo("/settings/locations", forceLoad: false);
            return;
        }

        _companyId = ctx.User.CompanyId;

        // Load the location and verify it belongs to the user's company
        var allLocations = _companyId.HasValue
            ? await LocationService.GetLocationsByCompanyAsync(_companyId.Value)
            : new List<Location>();

        _location = allLocations.FirstOrDefault(l => l.Id == LocationId);

        if (_location is not null && _companyId.HasValue)
        {
            _locationVendors = await VendorService.GetVendorsByLocationAsync(LocationId);
            _locationUnits   = await UnitService.GetByLocationAsync(LocationId);
            _storageLocations = await StorageLocService.GetByLocationAsync(LocationId);
        }

        _hydrated = true;
    }

    private void ToggleVendor(int vendorId) { }

    private async Task SaveVendors()
    {
        await Task.CompletedTask;
    }

    private async Task RemoveVendor(int vendorId)
    {
        await VendorService.RemoveVendorFromLocationAsync(LocationId, vendorId);
        _locationVendors = await VendorService.GetVendorsByLocationAsync(LocationId);
        StateHasChanged();
    }

    private void OpenAddVendorModal()
    {
        _newVendor = new Vendor();
        _searchQuery = string.Empty;
        _searchResults = new();
        _searchActiveIndex = -1;
        _selectedLogoUrl = null;
        _showAddVendorModal = true;
    }

    private void CloseAddVendorModal()
    {
        _searchCts?.Cancel();
        _showAddVendorModal = false;
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
        _searchActiveIndex = -1;

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        if (_searchQuery.Length < 2)
        {
            _searchResults = new();
            return;
        }

        _searching = true;
        StateHasChanged();

        try
        {
            await Task.Delay(300, token);
            _searchResults = await LogoDev.SearchAsync(_searchQuery, token);
        }
        catch (OperationCanceledException) { }
        finally
        {
            _searching = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (!_searchResults.Any()) return;

        if (e.Key == "ArrowDown")
        {
            _searchActiveIndex = Math.Min(_searchActiveIndex + 1, _searchResults.Count - 1);
        }
        else if (e.Key == "ArrowUp")
        {
            _searchActiveIndex = Math.Max(_searchActiveIndex - 1, 0);
        }
        else if (e.Key == "Enter" && _searchActiveIndex >= 0)
        {
            await SelectSearchResult(_searchResults[_searchActiveIndex]);
        }
        else if (e.Key == "Escape")
        {
            _searchResults = new();
        }
    }

    private Task SelectSearchResult(LogoDevResult result)
    {
        _newVendor.Name = result.Name;
        _newVendor.Website = $"https://{result.Domain}";
        _selectedLogoUrl = result.Logo_Url ?? BuildLogoUrl(result.Domain);
        _searchQuery = result.Name;
        _searchResults = new();
        return Task.CompletedTask;
    }

    private void ClearSelection()
    {
        _selectedLogoUrl = null;
        _searchQuery = string.Empty;
        _newVendor.Name = string.Empty;
        _newVendor.Website = string.Empty;
        _searchResults = new();
    }

    private string BuildLogoUrl(string domain)
    {
        var publishableKey = Config["LogoDev:PublishableKey"] ?? string.Empty;
        return LogoDev.BuildLogoUrl(domain, publishableKey);
    }

    private async Task CreateVendor()
    {
        if (_companyId is null) return;

        _creatingVendor = true;

        _newVendor.CompanyId = _companyId.Value;
        _newVendor.LogoUrl = _selectedLogoUrl;
        var created = await VendorService.CreateVendorAsync(_newVendor);

        // Always link the new vendor to this location
        await VendorService.AddVendorToLocationAsync(LocationId, created.Id);

        _locationVendors = await VendorService.GetVendorsByLocationAsync(LocationId);

        _creatingVendor = false;
        _showAddVendorModal = false;
        StateHasChanged();
    }

    // ── Units ─────────────────────────────────────────────────────────────────

    private async Task OpenAddUnitModal()
    {
        var all = await UnitService.GetAllAsync();
        var assignedIds = _locationUnits.Select(u => u.Id).ToHashSet();
        _availableUnitsToAdd = all.Where(u => !assignedIds.Contains(u.Id)).ToList();
        _selectedUnitId = 0;
        _showAddUnitModal = true;
    }

    private void CloseAddUnitModal()
    {
        _showAddUnitModal = false;
        _selectedUnitId = 0;
    }

    private async Task AddUnit()
    {
        if (_selectedUnitId == 0) return;

        _addingUnit = true;

        var currentIds = _locationUnits.Select(u => u.Id).ToList();
        currentIds.Add(_selectedUnitId);
        await UnitService.SetLocationUnitsAsync(LocationId, currentIds);
        _locationUnits = await UnitService.GetByLocationAsync(LocationId);

        _addingUnit = false;
        _showAddUnitModal = false;
        StateHasChanged();
    }

    private async Task RemoveUnit(int unitId)
    {
        var remaining = _locationUnits.Select(u => u.Id).Where(id => id != unitId);
        await UnitService.SetLocationUnitsAsync(LocationId, remaining);
        _locationUnits = await UnitService.GetByLocationAsync(LocationId);
        StateHasChanged();
    }

    private void OpenAddStorageLocationModal()
    {
        _newStorageLocationName = "";
        _storageLocationDeleteError = null;
        _showAddStorageLocationModal = true;
    }

    private void CloseAddStorageLocationModal()
    {
        _showAddStorageLocationModal = false;
        _newStorageLocationName = "";
    }

    private async Task CreateStorageLocation()
    {
        if (string.IsNullOrWhiteSpace(_newStorageLocationName)) return;

        _savingStorageLocation = true;
        try
        {
            await StorageLocService.AddAsync(new StorageLocation
            {
                Name = _newStorageLocationName.Trim(),
                LocationId = LocationId
            });
            _storageLocations = await StorageLocService.GetByLocationAsync(LocationId);
            CloseAddStorageLocationModal();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to create storage location: {ex}");
        }
        finally
        {
            _savingStorageLocation = false;
        }
    }

    private void StartEditStorageLocation(StorageLocation loc)
    {
        _editingStorageLocationId = loc.Id;
        _editingStorageLocationName = loc.Name ?? "";
        _storageLocationDeleteError = null;
    }

    private void CancelStorageLocationEdit()
    {
        _editingStorageLocationId = null;
        _editingStorageLocationName = "";
    }

    private async Task SaveStorageLocationEdit()
    {
        if (_editingStorageLocationId is null || string.IsNullOrWhiteSpace(_editingStorageLocationName)) return;

        _savingStorageLocation = true;
        try
        {
            var entity = _storageLocations.FirstOrDefault(l => l.Id == _editingStorageLocationId);
            if (entity is not null)
            {
                entity.Name = _editingStorageLocationName.Trim();
                await StorageLocService.UpdateAsync(entity);
                _storageLocations = await StorageLocService.GetByLocationAsync(LocationId);
            }
            CancelStorageLocationEdit();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to update storage location: {ex}");
        }
        finally
        {
            _savingStorageLocation = false;
        }
    }

    private async Task DeleteStorageLocation(int id)
    {
        _storageLocationDeleteError = null;
        try
        {
            var inUse = await StorageLocService.IsInUseAsync(id);
            if (inUse)
            {
                _storageLocationDeleteError = "This location is assigned to one or more ingredients. Reassign them first.";
                return;
            }
            await StorageLocService.DeleteAsync(id);
            _storageLocations = await StorageLocService.GetByLocationAsync(LocationId);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to delete storage location: {ex}");
        }
    }
}
