@rendermode InteractiveServer

@using CulinaryCommand.Data.Entities
@using CulinaryCommand.Services
@using CulinaryCommand.Services.UserContextSpace
@using CulinaryCommandApp.Inventory.Services.Interfaces
@using CulinaryCommandApp.Inventory.DTOs
@using Plotly.Blazor
@using Plotly.Blazor.Traces
@using Plotly.Blazor.LayoutLib

@inject ITaskAssignmentService TaskService
@inject IInventoryManagementService InventoryService
@inject LocationState LocationState
@implements IDisposable

<PageTitle>Dashboard</PageTitle>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        Loading dashboard…
    </div>
}
else if (LocationState.CurrentLocation is null)
{
    <div class="alert alert-info mt-3">No location selected. Pick a location to see dashboard data.</div>
}
else
{
    <!-- Row 1 ── Low Stock | Task Status Donut -->
    <div class="row g-4 mt-2">

        <div class="col-lg-8">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                    Low Stock Items
                    <span class="badge text-bg-danger ms-1">@_lowStockItems.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (_lowStockItems.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ingredient</th>
                                        <th>Category</th>
                                        <th>In Stock</th>
                                        <th>Reorder Level</th>
                                        <th>Unit</th>
                                        <th>Vendor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _lowStockItems)
                                    {
                                        <tr class="table-warning">
                                            <td>@item.Name</td>
                                            <td>@item.Category</td>
                                            <td>@item.CurrentQuantity.ToString("0.##")</td>
                                            <td>@item.ReorderLevel.ToString("0.##")</td>
                                            <td>@item.Unit</td>
                                            <td>@(item.VendorName ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center py-5">
                            <p class="text-muted mb-0">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>All items sufficiently stocked.
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold">Task Status Breakdown</div>
                <div class="card-body p-1">
                    @if (_taskData.Any())
                    {
                        <PlotlyChart @bind-Config="_chartConfig"
                                     @bind-Layout="_taskStatusLayout"
                                     @bind-Data="_taskStatusChartData" />
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">No tasks for this location.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2 ── Tasks per Employee | Live Activity -->
    <div class="row g-4 mt-2">

        <div class="col-lg-5">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold">Tasks Completed per Employee</div>
                <div class="card-body p-0">
                    @if (_empTaskCounts.Any())
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Employee</th>
                                    <th class="text-center">Completed</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in _empTaskCounts)
                                {
                                    <tr>
                                        <td>@e.Name</td>
                                        <td class="text-center">
                                            <span class="badge text-bg-success">@e.Count</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">No completed tasks yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card h-100 shadow-sm">
                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-activity me-1 text-primary"></i>Live Activity (Last 7 Days)</span>
                    <small class="text-muted">
                        <i class="bi bi-arrow-clockwise me-1"></i>@_activityRefreshedAt.ToLocalTime().ToString("HH:mm:ss")
                    </small>
                </div>
                <div class="card-body p-0" style="max-height:320px;overflow-y:auto;">
                    @if (_activityItems.Any())
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width:1%"></th>
                                    <th>Activity</th>
                                    <th class="text-nowrap">When</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _activityItems)
                                {
                                    <tr>
                                        <td class="ps-2">
                                            <i class="bi @StatusIcon(item.Status) @StatusColor(item.Status)"></i>
                                        </td>
                                        <td>@item.Description</td>
                                        <td class="text-muted text-nowrap small">@FormatWhen(item.When)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center py-5">
                            <p class="text-muted mb-0"><i class="bi bi-calendar-x me-2"></i>No activity in the last 7 days.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;

    private List<InventoryItemDTO> _lowStockItems = new();
    private List<Tasks> _taskData = new();
    private List<(string Name, int Count)> _empTaskCounts = new();
    private List<ActivityItem> _activityItems = new();
    private DateTime _activityRefreshedAt = DateTime.UtcNow;

    private Config _chartConfig = new() { Responsive = true };

    private Layout _taskStatusLayout = new()
    {
        Height = 280,
        Margin = new Margin { T = 10, B = 30, L = 10, R = 10 },
        ShowLegend = true
    };

    private IList<ITrace> _taskStatusChartData = new List<ITrace>();

    private record ActivityItem(string Description, string Status, DateTime When);

    protected override async Task OnInitializedAsync()
    {
        LocationState.OnChange += HandleLocationChange;
        await LoadDataAsync();
    }

    private void HandleLocationChange()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    private async Task LoadDataAsync()
    {
        var locId = LocationState.CurrentLocation?.Id;
        if (locId is null)
        {
            _loading = false;
            return;
        }

        _loading = true;

        var allItems = await InventoryService.GetItemsByLocationAsync(locId.Value);
        _lowStockItems = allItems.Where(i => i.IsLowStock).ToList();

        _taskData = await TaskService.GetByLocationAsync(locId.Value);

        _empTaskCounts = _taskData
            .Where(t => string.Equals(t.Status, "Completed", StringComparison.OrdinalIgnoreCase)
                     && t.User?.Name != null)
            .GroupBy(t => t.User!.Name!)
            .Select(g => (Name: g.Key, Count: g.Count()))
            .OrderByDescending(e => e.Count)
            .ToList();

        var cutoff = DateTime.UtcNow.AddDays(-7);
        _activityItems = _taskData
            .Where(t => t.UpdatedAt >= cutoff)
            .OrderByDescending(t => t.UpdatedAt)
            .Take(50)
            .Select(t => new ActivityItem(BuildDescription(t), t.Status ?? "Unknown", t.UpdatedAt))
            .ToList();

        BuildCharts();

        _activityRefreshedAt = DateTime.UtcNow;
        _loading = false;
    }

    private void BuildCharts()
    {
        var groups = _taskData
            .GroupBy(t => t.Status ?? "Unknown")
            .ToList();

        _taskStatusChartData = new List<ITrace>
        {
            new Pie
            {
                Labels = groups.Select(g => (object)g.Key).ToList(),
                Values = groups.Select(g => (object)(double)g.Count()).ToList(),
                Hole = 0.5m
            }
        };
    }

    private static string BuildDescription(Tasks t)
    {
        var station = !string.IsNullOrWhiteSpace(t.Station) ? $" ({t.Station})" : "";
        var taskName = $"\"{t.Name}\"{station}";

        if (string.IsNullOrWhiteSpace(t.User?.Name))
        {
            var pastTense = (t.Status ?? "").ToLowerInvariant() switch
            {
                "completed"   => "marked complete",
                "in progress" => "started",
                "pending"     => "set to pending",
                _             => "updated"
            };
            return $"{taskName} was {pastTense}";
        }

        var action = (t.Status ?? "").ToLowerInvariant() switch
        {
            "completed"   => "completed",
            "in progress" => "started",
            "pending"     => "was assigned",
            _             => "updated"
        };
        return $"{t.User.Name} {action} {taskName}";
    }

    private static string StatusIcon(string status) => status.ToLowerInvariant() switch
    {
        "completed"   => "bi-check-circle-fill",
        "in progress" => "bi-arrow-repeat",
        "pending"     => "bi-clock",
        _             => "bi-dash-circle"
    };

    private static string StatusColor(string status) => status.ToLowerInvariant() switch
    {
        "completed"   => "text-success",
        "in progress" => "text-primary",
        "pending"     => "text-warning",
        _             => "text-muted"
    };

    private static string FormatWhen(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 1)  return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)   return $"{(int)diff.TotalHours}h ago";
        return utc.ToLocalTime().ToString("MMM d, h:mm tt");
    }

    public void Dispose()
    {
        LocationState.OnChange -= HandleLocationChange;
    }
}
