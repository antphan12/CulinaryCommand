@using CulinaryCommand.Data.Entities

@if (IsOpen && TaskList != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title">Manage Templates - @TaskList.Name</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Add templates to this list</label>
                        <div style="max-height: 280px; overflow-y: auto;" class="border rounded-3 p-3 bg-light">
                            @if (!AvailableTemplates.Any())
                            {
                                <div class="text-muted small">No templates available.</div>
                            }
                            else
                            {
                                @foreach (var template in AvailableTemplates)
                                {
                                    var isSelected = SelectedTemplateIds.Contains(template.Id);

                                    <div class="form-check mb-2">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               checked="@isSelected"
                                               @onchange="() => ToggleTemplate(template.Id)" />
                                        <label class="form-check-label">
                                            <strong>@template.Name</strong> - @template.Station
                                        </label>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <button class="btn btn-success btn-sm" @onclick="SaveSelectedTemplates" disabled="@IsSaving">
                            @(IsSaving ? "Saving..." : "Add Selected Templates")
                        </button>
                    </div>

                    <hr />

                    <div>
                        <label class="form-label">Templates currently in this list</label>

                        <div style="max-height: 240px; overflow-y: auto;">
                            @if (!CurrentTemplates.Any())
                            {
                                <div class="text-muted small">No templates in this task list yet.</div>
                            }
                            else
                            {
                                @foreach (var template in CurrentTemplates)
                                {
                                    <div class="d-flex justify-content-between align-items-center border rounded-3 p-2 mb-2">
                                        <div>
                                            <div class="fw-semibold">@template.Name</div>
                                            <div class="text-muted small">@template.Station</div>
                                        </div>

                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RemoveTemplate.InvokeAsync(template.Id)">
                                            Remove
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="Close">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public TaskList? TaskList { get; set; }
    [Parameter] public List<TaskTemplate> AvailableTemplates { get; set; } = new();
    [Parameter] public List<TaskTemplate> CurrentTemplates { get; set; } = new();
    [Parameter] public EventCallback<List<int>> OnAddTemplates { get; set; }
    [Parameter] public EventCallback<int> RemoveTemplate { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private HashSet<int> SelectedTemplateIds = new();
    private bool IsSaving;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            SelectedTemplateIds = new HashSet<int>();
        }
    }

    private void ToggleTemplate(int templateId)
    {
        if (!SelectedTemplateIds.Add(templateId))
        {
            SelectedTemplateIds.Remove(templateId);
        }
    }

    private async Task SaveSelectedTemplates()
    {
        IsSaving = true;
        await OnAddTemplates.InvokeAsync(SelectedTemplateIds.ToList());
        SelectedTemplateIds.Clear();
        IsSaving = false;
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}