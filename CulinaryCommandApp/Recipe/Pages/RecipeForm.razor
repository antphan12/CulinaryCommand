@rendermode InteractiveServer
@implements IDisposable

@using CulinaryCommand.Services
@using CulinaryCommand.Services.UserContextSpace
@using CulinaryCommandApp.Inventory.Entities
@using CulinaryCommandApp.Inventory.Services
@using CulinaryCommandApp.Inventory.Services.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using System.Threading
@inject IIngredientService IngredientService
@inject IUnitService UnitService
@inject IRecipeService RecipeService
@inject EnumService EnumService
@inject IUserContextService UserCtx
@inject LocationState LocationState
@inject NavigationManager Nav

@*---------------------------------------------------------------
CONCURRENCY CONFLICT BANNER
-> Pops up when a DbUpdateConcurrencyException is caught on save.
---------------------------------------------------------------*@
@if (_conflictDetected) {
    <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
        <div class="flex-grow-1">
            <strong>Save conflict detected.</strong>
            <p class="mb-2">
                Another user saved this recipe while you were editing. Choose how to proceed.
            </p>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="ReloadLatest"
                        disabled="@_saving">
                    <i class="bi bi-arrow-clockwise me-1"></i>Reload latest
                </button>
                <button class="btn btn-sm btn-warning"
                        @onclick="ForceOverwrite"
                        disabled="@_saving">
                    <i class="bi bi-floppy me-1"></i> Overwrite anyway
                </button>
                <button class="btn btn-sm btn-link text-secondary p-0"
                        @onclick="DismissConflict">
                    Dismiss
                </button>
            </div>
        </div>
    </div>
}

@*------------------
GENERIC ERROR BANNER
------------------*@

@if (!string.IsNullOrWhiteSpace(_errorMessage)) {
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-x-circle-fill"></i>
        <span>@_errorMessage</span>
        <button type="button" class="btn-close ms-auto" @onclick="() => _errorMessage = null"></button>
    </div>
}

@*-----------
LOADING STATE
-----------*@

@if (!_ready) {
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else {
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h4 class="mb-0">@FormTitle</h4>
            @if (Model.RecipeId > 0)
            {
                <span class="badge bg-secondary">ID: @Model.RecipeId</span>
            }
        </div>

        <div class="card-body">
            @* ---- Section 1: Basic metadata ---- *@
            <h6 class="text-uppercase text-muted fw-semibold mb-3">Recipe Details</h6>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Title <span class="text-danger">*</span>
                    </label>
                    <input class="form-control @(string.IsNullOrWhiteSpace(Model.Title) && _submitAttempted ? "is-invalid" : "")"
                           @bind="Model.Title"
                           placeholder="e.g. Caesar Salad" />
                    @if (string.IsNullOrWhiteSpace(Model.Title) && _submitAttempted)
                    {
                        <div class="invalid-feedback">Title is required.</div>
                    }
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Category</label>
                    <select class="form-select" @bind="Model.Category">
                        <option value="">-- Select Category --</option>
                        @foreach (var category in _recipeCategories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Recipe Type</label>
                    <select class="form-select" @bind="Model.RecipeType">
                        <option value="">-- Select Type --</option>
                        @foreach (var type in _recipeTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Yield Amount</label>
                    <input class="form-control"
                           type="number"
                           min="0"
                           step="0.01"
                           value="@(Model.YieldAmount.HasValue ? Math.Round(Model.YieldAmount.Value, 2).ToString("0.##") : "")"
                           @onchange="(e) => Model.YieldAmount = decimal.TryParse(e.Value?.ToString(), out var v) ? v : null"
                           placeholder="e.g. 4" />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Yield Unit</label>
                    <select class="form-select" @bind="Model.YieldUnit">
                        <option value="">-- Select Unit --</option>
                        @foreach (var unit in _locationUnits)
                        {
                            <option value="@unit.Name">@unit.Name (@unit.Abbreviation)</option>
                        }
                    </select>
                </div>
            </div>

            @* Toggle sub-recipe*@
            <div class="form-check form-switch mb-4">
                <input class="form-check-input"
                       type="checkbox"
                       id="isSubRecipeToggle"
                       @bind="Model.IsSubRecipe" />
                <label class="form-check-label fw-semibold" for="isSubRecipeToggle">
                    This recipe is a sub-recipe (prep item used inside other recipes)
                </label>
                <div class="form-text">
                    When enabled, this recipe will appear in the sub-recipe picker of other recipes.
                </div>
            </div>

            <hr />

            @* ---- Section: Recipe Image ---- *@
            <h6 class="text-uppercase text-muted fw-semibold mb-3">Recipe Image</h6>

            <div class="mb-4">
                <div class="rf-image-card">
                    @if (!string.IsNullOrWhiteSpace(Model.ImageData))
                    {
                        <div class="rf-image-preview">
                            <img src="@Model.ImageData" alt="Recipe preview" class="rf-preview-img" />
                            <button type="button" class="rf-remove-img" @onclick="RemoveImage" title="Remove image">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="rf-image-placeholder">
                            <i class="bi bi-image"></i>
                            <p>No image uploaded</p>
                            <p class="rf-upload-hint">JPG, PNG or WEBP · max 5 MB</p>
                        </div>
                    }
                </div>
                <InputFile id="recipeImageInput"
                           class="form-control mt-2"
                           accept="image/*"
                           OnChange="HandleImageUpload" />
                @if (!string.IsNullOrWhiteSpace(_imageError))
                {
                    <div class="text-danger small mt-1">@_imageError</div>
                }
            </div>

            <hr />

            @* ---- Section: Serving Info ---- *@
            <h6 class="text-uppercase text-muted fw-semibold mb-3">Serving &amp; Nutrition</h6>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Portion Size</label>
                    <input class="form-control"
                           placeholder="e.g. 6 oz serving"
                           @bind="Model.PortionSize" />
                </div>
            </div>

            @* Allergens *@
            <div class="mb-4">
                <label class="form-label fw-semibold">Allergens</label>
                <input class="form-control"
                       placeholder="e.g. Fish, Gluten, Nuts"
                       @bind="Model.Allergens" />
                <div class="form-text">Comma-separate multiple allergens.</div>
            </div>

            <hr />

            @* ---- Section 2: Ingredient Lines ----*@
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-uppercase text-muted fw-semibold mb-0">Ingredients</h6>
                <button type="button" class="btn btn-sm btn-outline-success" @onclick="AddIngredientLine">
                    <i class="bi bi-plus-circle me-1"></i>Add Line
                </button>
            </div>

            @if (!_ingredientLines.Any())
            {
                <p class="text-muted fst-italic mb-3">No ingredients added yet.</p>
            }

            @foreach (var line in _ingredientLines.OrderBy(l => l.SortOrder))
            {
                <div class="card mb-2 border-0 bg-light">
                    <div class="card-body py-2 px-3">

                        @* Mode toggle *@
                        <div class="d-flex gap-2 mb-2">
                            <button type="button"
                                    class="btn btn-sm @(!line.IsSubRecipeMode ? "btn-success" : "btn-outline-secondary")"
                                    @onclick="() => SetLineMode(line, false)">
                                <i class="bi bi-basket me-1"></i>Ingredient
                            </button>
                            <button type="button"
                                    class="btn btn-sm @(line.IsSubRecipeMode ? "btn-success" : "btn-outline-secondary")"
                                    @onclick="() => SetLineMode(line, true)">
                                <i class="bi bi-diagram-3 me-1"></i>Sub-Recipe
                            </button>
                        </div>

                        <div class="row g-2 align-items-end">

                            @if (!line.IsSubRecipeMode)
                            {
                                @* Category to Ingredient cascade *@
                                <div class="col-md-3">
                                    <label class="form-label form-label-sm">Category</label>
                                    <select class="form-select form-select-sm"
                                            value="@line.SelectedCategory"
                                            @onchange="(e) => OnLineCategoryChanged(line, e.Value?.ToString())">
                                        <option value="">-- Category --</option>
                                        @foreach (var category in _ingredientCategories)
                                        {
                                            <option value="@category">@category</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label form-label-sm">Ingredient</label>
                                    <select class="form-select form-select-sm"
                                            value="@line.IngredientId"
                                            @onchange="(e) => OnLineIngredientChanged(line, e.Value?.ToString())">
                                        <option value="">-- Ingredient --</option>
                                        @foreach (var ingredient in line.FilteredIngredients)
                                        {
                                            <option value="@ingredient.Id">@ingredient.Name</option>
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6">
                                    <label class="form-label form-label-sm">Sub-Recipe</label>
                                    <select class="form-select form-select-sm"
                                            value="@line.SubRecipeId"
                                            @onchange="(e) => OnLineSubRecipeChanged(line, e.Value?.ToString())">
                                        <option value="">-- Sub-Recipe --</option>
                                        @foreach (var subRecipe in _availableSubRecipes)
                                        {
                                            <option value="@subRecipe.RecipeId">@subRecipe.Title</option>
                                        }
                                    </select>
                                </div>
                            }

                            <div class="col-md-2">
                                <label class="form-label form-label-sm">Qty</label>
                                <input type="number"
                                       class="form-control form-control-sm"
                                       min="0"
                                       step="0.01"
                                       value="@Math.Round(line.Quantity, 2).ToString("0.##")"
                                       @onchange="(e) => line.Quantity = decimal.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                            </div>

                            <div class="col-md-2">
                                <label class="form-label form-label-sm">Unit</label>
                                <select class="form-select form-select-sm"
                                        value="@line.UnitId"
                                        @onchange="(e) => OnLineUnitChanged(line, e.Value?.ToString())">
                                    <option value="0">-- Unit --</option>
                                    @foreach (var unit in _locationUnits)
                                    {
                                        <option value="@unit.Id">@unit.Abbreviation</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label form-label-sm">Prep Note</label>
                                <input class="form-control form-control-sm"
                                       placeholder="e.g. diced"
                                       @bind="line.PrepNote" />
                            </div>

                            <div class="col-auto">
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        @onclick="() => RemoveIngredientLine(line)"
                                        title="Remove line">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <hr />

            @* ---- Section 3: Steps ---- *@

            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-uppercase text-muted fw-semibold mb-0">Preparation Steps</h6>
                <button type="button" class="btn btn-sm btn-outline-success" @onclick="AddStep">
                    <i class="bi bi-plus-circle me-1"></i>Add Step
                </button>
            </div>

            @if (!Model.Steps.Any())
            {
                <p class="text-muted fst-italic mb-3">No steps added yet.</p>
            }

            @foreach (var step in Model.Steps.OrderBy(s => s.StepNumber))
            {
                <div class="card mb-2 border-0 bg-light">
                    <div class="card-body py-2 px-3">
                        <div class="row g-2 align-items-start">

                            <div class="col-auto d-flex flex-column gap-1 pt-1">
                                <span class="badge bg-success rounded-pill" style="min-width:2rem;">
                                    @step.StepNumber
                                </span>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger p-1"
                                        @onclick="() => RemoveStep(step)"
                                        title="Remove step">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>

                            <div class="col">
                                <textarea class="form-control form-control-sm"
                                          rows="3"
                                          maxlength="2048"
                                          placeholder="Describe this step in detail..."
                                          @bind="step.Instructions"></textarea>
                            </div>

                            <div class="col-md-3">
                                <div class="mb-2">
                                    <label class="form-label form-label-sm">Duration (optional)</label>
                                    <input class="form-control form-control-sm"
                                           maxlength="64"
                                           placeholder="e.g. 8-10 min"
                                           @bind="step.Duration" />
                                </div>
                                <div class="mb-2">
                                    <label class="form-label form-label-sm">Temp (optional)</label>
                                    <input class="form-control form-control-sm"
                                           maxlength="64"
                                           placeholder="e.g. 375 F"
                                           @bind="step.Temperature" />
                                </div>
                                <div>
                                    <label class="form-label form-label-sm">Equipment (optional)</label>
                                    <input class="form-control form-control-sm"
                                           maxlength="256"
                                           placeholder="e.g. grill, saute pan"
                                           @bind="step.Equipment" />
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }

            <hr />

            @* ---- Section 4: Actions ---- *@
            <div class="d-flex gap-2">
                <button class="btn btn-success"
                        @onclick="Save"
                        disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <i class="bi bi-floppy me-1"></i>
                        <span>Save Recipe</span>
                    }
                </button>

                <button class="btn btn-outline-secondary"
                        @onclick="Cancel"
                        disabled="@_saving">
                    Cancel
                </button>
            </div>

        </div>
    </div>
}

@code {

    [Parameter] public Recipe Model { get; set; } = new();
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public string FormTitle { get; set; } = "Recipe";

    // UI State
    private bool _ready;
    private bool _conflictDetected;
    private bool _saving;
    private bool _submitAttempted;
    private string? _errorMessage;
    private bool _dataLoaded;
    private bool _dataLoading;
    private readonly SemaphoreSlim _loadSemaphore = new(1, 1);

    // Image upload
    private string? _imageError;

    // Reference data
    private List<string> _recipeTypes = new();
    private List<string> _recipeCategories = new();
    private List<string> _ingredientCategories = new();
    private List<Unit> _locationUnits = new();
    private List<Ingredient> _locationIngredients = new();
    private List<Recipe> _availableSubRecipes = new();

    private List<IngredientLineViewModel> _ingredientLines = new();

    protected override async Task OnInitializedAsync() {
        _recipeCategories = EnumService.GetCategories();
        _recipeTypes = EnumService.GetRecipeTypes();

        LocationState.OnChange += HandleLocationChanged;

        if (LocationState.CurrentLocation is not null)
        {
            await LoadLocationDataAsync();
        }

        _ready = true;
    }


    private void HandleLocationChanged()
    {
        // Schedule the async work without blocking the caller. Use a semaphore
        // to ensure only one LoadLocationDataAsync runs at a time instead of
        // polling _dataLoading.
        _ = InvokeAsync(async () =>
        {
            await _loadSemaphore.WaitAsync();
            try
            {
                _dataLoaded = false;
                await LoadLocationDataAsync();
                StateHasChanged();
            }
            finally
            {
                _loadSemaphore.Release();
            }
        });
    }

    public void Dispose()
    {
        LocationState.OnChange -= HandleLocationChanged;
        _loadSemaphore.Dispose();
    }

    private async Task LoadLocationDataAsync() {
        if (_dataLoading) return;  // prevent concurrent DB calls on same DbContext
        _dataLoading = true;

        try {
            var location = LocationState.CurrentLocation;

            if (location is not null) {
                Model.LocationId = location.Id;

                _locationUnits = await UnitService.GetByLocationAsync(location.Id);

                // Fall back to all units if none have been assigned to this location yet
                if (!_locationUnits.Any())
                    _locationUnits = await UnitService.GetAllAsync();

                _locationIngredients = await IngredientService.GetIngredientsByLocationAsync(location.Id);

                // Fall back to all ingredients if none have been added to this location yet
                if (!_locationIngredients.Any())
                    _locationIngredients = await IngredientService.GetAllAsync();

                var allLocationRecipes = await RecipeService.GetAllByLocationIdAsync(location.Id);
                _availableSubRecipes = allLocationRecipes
                    .Where(r => r.IsSubRecipe && r.RecipeId != Model.RecipeId)
                    .ToList();
            }

            _ingredientCategories = _locationIngredients
                .Select(i => i.Category)
                .Distinct()
                .OrderBy(c => c)
                .ToList();

            RebuildLineViewModels();
            _dataLoaded = true;
        }
        finally {
            _dataLoading = false;
        }
    }

    // *** Ingredient line helpers ***

    private void RebuildLineViewModels() {
        _ingredientLines = Model.RecipeIngredients
            .Select(ri => {
                var vm = new IngredientLineViewModel(ri);
                if (ri.IngredientId.HasValue) {
                    var ingredient = _locationIngredients.FirstOrDefault(i => i.Id == ri.IngredientId);
                    if (ingredient is not null) {
                        vm.SelectedCategory = ingredient.Category;
                        vm.FilteredIngredients = _locationIngredients
                            .Where(i => i.Category == ingredient.Category)
                            .OrderBy(i => i.Name)
                            .ToList();
                    }
                }
                return vm;
            })
            .ToList();
    }

    private void AddIngredientLine() {
        var ri = new RecipeIngredient { SortOrder = _ingredientLines.Count + 1 };
        Model.RecipeIngredients.Add(ri);
        _ingredientLines.Add(new IngredientLineViewModel(ri));
    }

    private void RemoveIngredientLine(IngredientLineViewModel vm) {
        Model.RecipeIngredients.Remove(vm.Source);
        _ingredientLines.Remove(vm);
        for (int i = 0; i < _ingredientLines.Count; i++)
            _ingredientLines[i].SortOrder = i + 1;
    }

    private void SetLineMode(IngredientLineViewModel vm, bool subRecipeMode) {
        vm.IsSubRecipeMode = subRecipeMode;
        if (subRecipeMode) {
            vm.Source.IngredientId = null;
            vm.SelectedCategory = null;
            vm.FilteredIngredients = new();
        }
        else {
            vm.Source.SubRecipeId = null;
        }
    }

    private void OnLineCategoryChanged(IngredientLineViewModel vm, string? category) {
        vm.SelectedCategory = category;
        vm.Source.IngredientId = null;
        vm.FilteredIngredients = string.IsNullOrWhiteSpace(category)
            ? new()
            : _locationIngredients.Where(i => i.Category == category).OrderBy(i => i.Name).ToList();
    }

    private void OnLineIngredientChanged(IngredientLineViewModel vm, string? raw) {
        if (int.TryParse(raw, out var id)) {
            vm.Source.IngredientId = id;
            // Auto-select the ingredient's default unit if no unit is chosen yet
            if (vm.Source.UnitId == 0) {
                var ingredient = _locationIngredients.FirstOrDefault(i => i.Id == id);
                if (ingredient is not null)
                    vm.Source.UnitId = ingredient.UnitId;
            }
        } else {
            vm.Source.IngredientId = null;
        }
    }

    private void OnLineSubRecipeChanged(IngredientLineViewModel vm, string? raw) =>
        vm.Source.SubRecipeId = int.TryParse(raw, out var id) ? id : null;

    private void OnLineUnitChanged(IngredientLineViewModel vm, string? raw) {
        if (int.TryParse(raw, out var id)) vm.Source.UnitId = id;
    }

    // *** Step logic ***

    private void AddStep() {
        Model.Steps.Add(new RecipeStep { StepNumber = Model.Steps.Count + 1 });
    }

    private void RemoveStep(RecipeStep step) {
        Model.Steps.Remove(step);
        int i = 1;
        foreach (var s in Model.Steps.OrderBy(x => x.StepNumber))
            s.StepNumber = i++;
    }

    // *** Save logic ***

    private async Task Save() {
        _submitAttempted = true;
        _errorMessage = null;
        _conflictDetected = false;

        if (string.IsNullOrWhiteSpace(Model.Title))
            return;

        // Validate all lines: UnitId is non-nullable in the schema and required
        // for inventory transactions, so every line (ingredient or sub-recipe) must
        // have a unit selected before saving. Also ensure each line has exactly one
        // of IngredientId / SubRecipeId set so no orphaned lines reach the database.
        var missingUnit = _ingredientLines
            .Where(l => l.Source.UnitId == 0)
            .ToList();
        if (missingUnit.Any())
        {
            _errorMessage = $"{missingUnit.Count} line(s) are missing a unit. Please select a unit for every ingredient and sub-recipe line.";
            _saving = false;
            return;
        }

        var missingReference = _ingredientLines
            .Where(l => l.Source.IngredientId is null && l.Source.SubRecipeId is null)
            .ToList();
        if (missingReference.Any())
        {
            _errorMessage = $"{missingReference.Count} line(s) have no ingredient or sub-recipe selected. Please complete or remove them before saving.";
            _saving = false;
            return;
        }

        _saving = true;

        try {
            if (Model.RecipeId == 0) {
                Model.CreatedAt = DateTime.UtcNow;
                await RecipeService.CreateAsync(Model);
            }
            else {
                await RecipeService.UpdateAsync(Model);
            }

            await OnValidSubmit.InvokeAsync();
        }
        catch (DbUpdateConcurrencyException) {
            _conflictDetected = true;
        }
        catch (Exception ex) {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally {
            _saving = false;
        }
    }

    // *** Conflict resolution ***

    private async Task ReloadLatest()
    {
        if (Model.RecipeId == 0) return;

        _saving = true;

        try
        {
            var latest = await RecipeService.GetByIdAsync(Model.RecipeId);

            if (latest is null)
            {
                _errorMessage = "Recipe no longer exists.";
                return;
            }

            // Update scalar properties on the existing Model instance so bindings remain intact.
            Model.Title = latest.Title;
            Model.Category = latest.Category;
            Model.RecipeType = latest.RecipeType;
            Model.YieldAmount = latest.YieldAmount;
            Model.YieldUnit = latest.YieldUnit;
            Model.IsSubRecipe = latest.IsSubRecipe;
            Model.CreatedAt = latest.CreatedAt;
            Model.LocationId = latest.LocationId;
            Model.RowVersion = latest.RowVersion;

            // Replace ingredient and step collections with the latest server copies
            Model.RecipeIngredients.Clear();
            foreach (var ri in (latest.RecipeIngredients ?? Enumerable.Empty<RecipeIngredient>()).OrderBy(r => r.SortOrder))
                Model.RecipeIngredients.Add(ri);

            Model.Steps.Clear();
            foreach (var s in (latest.Steps ?? Enumerable.Empty<RecipeStep>()).OrderBy(s => s.StepNumber))
                Model.Steps.Add(s);

            // Rebuild derived view models and refresh UI
            RebuildLineViewModels();
            _conflictDetected = false;
            StateHasChanged();
        }
        catch (Exception)
        {
            _errorMessage = $"Could not reload.";
            // add logging later
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ForceOverwrite()
    {
        if (Model.RecipeId == 0) return;

        _saving = true;
        _errorMessage = null;

        try
        {
            // Snapshot every user edit that is currently in Model so we can
            // restore them after fetching the latest concurrency token.
            var titleSnapshot        = Model.Title;
            var categorySnapshot     = Model.Category;
            var recipeTypeSnapshot   = Model.RecipeType;
            var yieldAmountSnapshot  = Model.YieldAmount;
            var yieldUnitSnapshot    = Model.YieldUnit;
            var isSubRecipeSnapshot  = Model.IsSubRecipe;
            var locationIdSnapshot   = Model.LocationId;
            var createdAtSnapshot    = Model.CreatedAt;
            var ingredientsSnapshot  = Model.RecipeIngredients.ToList();
            var stepsSnapshot        = Model.Steps.ToList();

            // Fetch only the token — do NOT overwrite the user's edits.
            var freshToken = await RecipeService.GetRowVersionAsync(Model.RecipeId);

            if (freshToken is null)
            {
                _errorMessage = "Recipe no longer exists and cannot be saved.";
                return;
            }

            // Stamp the new token so EF Core's concurrency check will pass.
            Model.RowVersion = freshToken.Value;

            // Restore the user's in-flight edits (unchanged by the fetch above).
            Model.Title           = titleSnapshot;
            Model.Category        = categorySnapshot;
            Model.RecipeType      = recipeTypeSnapshot;
            Model.YieldAmount     = yieldAmountSnapshot;
            Model.YieldUnit       = yieldUnitSnapshot;
            Model.IsSubRecipe     = isSubRecipeSnapshot;
            Model.LocationId      = locationIdSnapshot;
            Model.CreatedAt       = createdAtSnapshot;

            Model.RecipeIngredients.Clear();
            foreach (var ri in ingredientsSnapshot)
                Model.RecipeIngredients.Add(ri);

            Model.Steps.Clear();
            foreach (var s in stepsSnapshot)
                Model.Steps.Add(s);

            _conflictDetected = false;
        }
        catch (Exception)
        {
            _errorMessage = $"Could not prepare overwrite.";
            return;
        }
        finally
        {
            _saving = false;
        }

        await Save();
    }

    private void DismissConflict() => _conflictDetected = false;

    private void Cancel() => Nav.NavigateTo("/recipes");

    // *** Image upload ***

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        _imageError = null;
        var file = e.File;

        const long maxBytes = 5 * 1024 * 1024; // 5 MB
        if (file.Size > maxBytes)
        {
            _imageError = "Image must be under 5 MB.";
            return;
        }

        if (!file.ContentType.StartsWith("image/"))
        {
            _imageError = "Please select a valid image file.";
            return;
        }

        try
        {
            using var ms = new System.IO.MemoryStream();
            await using var stream = file.OpenReadStream(maxBytes);
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            Model.ImageData = $"data:{file.ContentType};base64,{base64}";
        }
        catch
        {
            _imageError = "Failed to read the image. Please try again.";
        }
    }

    private void RemoveImage()
    {
        Model.ImageData = null;
    }

